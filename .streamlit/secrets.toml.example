# 이 파일을 복사해서 .streamlit/secrets.toml 로 저장한 뒤 실제 값으로 채운다.
# secrets.toml은 .gitignore에 포함되어 있어 git에는 올라가지 않는다.

# 업체 데이터를 저장할 구글 시트 주소 (주소창에 보이는 전체 URL)
SHEET_URL = "https://docs.google.com/spreadsheets/d/여기에_시트_ID/edit"

# 삭제 기능을 잠글 관리자 암호.
# 이 값을 적어두면 업체 삭제 / 상품군 삭제 / 공용 재료 삭제는 암호를 아는 사람만 할 수 있다.
# (등록과 수정은 잠기지 않는다. 이 줄이 없으면 예전처럼 누구나 삭제할 수 있다.)
# 반드시 [gcp_service_account] 줄보다 위에 적어야 한다. 아래에 적으면 그 섹션의 값으로 들어가 버린다.
ADMIN_PASSWORD = "여기에_원하는_암호"


# 구글 클라우드에서 발급받은 서비스 계정 키(JSON)의 내용을 그대로 옮겨 적는다.
# 다운로드한 JSON 파일을 열어 각 key: value를 아래 형식으로 옮기면 된다.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = "-----BEGIN PRIVATE KEY-----\nMIIExampleKeyContentHere\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project-id.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project-id.iam.gserviceaccount.com"
